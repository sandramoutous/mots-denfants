<!DOCTYPE html>
<html>
  <head>
    <title>Mots d'enfants</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", media: "all" %>
    <%= stylesheet_link_tag "devise", media: "all" %>
    <%= stylesheet_link_tag "variables", media: "all" %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600&family=Nunito:wght@400;700&display=swap" rel="stylesheet">
  </head>
  <body class="auth-page">
    <div class="auth-card">
      <div class="auth-logo">
        <svg viewBox="0 0 200 100" class="rainbow-small">
          <path d="M 10 100 A 90 90 0 0 1 190 100" fill="none" stroke="var(--color-primary)" stroke-width="16" stroke-linecap="round"/>
          <path d="M 28 100 A 72 72 0 0 1 172 100" fill="none" stroke="var(--color-accent)" stroke-width="16" stroke-linecap="round"/>
          <path d="M 46 100 A 54 54 0 0 1 154 100" fill="none" stroke="var(--color-secondary)" stroke-width="16" stroke-linecap="round"/>
        </svg>
        <span class="auth-brand">mots-denfants</span>
      </div>
      <%= yield %>
    </div>
  </body>
</html>
