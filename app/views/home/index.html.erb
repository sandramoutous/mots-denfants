<!-- app/views/home/index.html.erb -->
<div class="hero">
  <div class="floating-words" aria-hidden="true">
    <span class="word word-1">maman</span>
    <span class="word word-2">dodo</span>
    <span class="word word-3">encore !</span>
    <span class="word word-4">non</span>
    <span class="word word-5">papa</span>
    <span class="word word-6">miam</span>
  </div>

  <div class="hero-content">
    <div class="rainbow-wrapper" aria-hidden="true">
      <svg viewBox="0 0 200 100" class="rainbow">
        <path d="M 10 100 A 90 90 0 0 1 190 100" fill="none" stroke="var(--color-primary)" stroke-width="16" stroke-linecap="round"/>
        <path d="M 28 100 A 72 72 0 0 1 172 100" fill="none" stroke="var(--color-accent)" stroke-width="16" stroke-linecap="round"/>
        <path d="M 46 100 A 54 54 0 0 1 154 100" fill="none" stroke="var(--color-secondary)" stroke-width="16" stroke-linecap="round"/>
      </svg>
    </div>
    <span class="eyebrow">Mots d'enfants</span>
    <h1>Ses premiers mots.<br>Tu voudras t'en rappeler.</h1>
    <p class="tagline">
      Garde une trace des premiers mots de ton enfant,
      au moment où ils arrivent. Il ne le dira qu'une fois comme ça.
      Toi, tu t'en souviendras toujours.
    </p>

    <% if user_signed_in? %>
      <%= link_to "Voir mes enfants", children_path, class: "btn-primary" %>
    <% else %>
      <%= link_to "Commencer", new_user_registration_path, class: "btn-primary" %>
      <%= link_to "Se connecter", new_user_session_path, class: "btn-secondary" %>
    <% end %>
  </div>
</div>